ROOT_URL=https://sclab-onprem
HTTP_FORWARDED_COUNT=1
LOG_LEVEL=debug

LOG_PATH=/data/logs
USE_FILE_LOG=1
LOG_FILE_COUNT=31

MONGO_URL=mongodb://root:changeThisMongoPassword@mongo:27017/sclab?authSource=admin
NODE_ENV=production
MONGO_DB_READ_PREFERENCE=primaryPreferred
MONGO_DB_POOL_SIZE=20
METEORD_NODE_OPTIONS=--max-old-space-size=4096
MAIL_URL=smtp://mail:25
NODE_TLS_REJECT_UNAUTHORIZED=0

# ai service
QDRANT_CLUSTER_URL="http://qdrant:6333"
QDRANT_API_KEY="changeThisQdrantApiKey"
OPENAI_KEY="openAiApiKeyHere"
GEMINI_API_KEY="geminiApiKeyHere"
OLLAMA_API_HOST="http://ollama:11434"
VLLM_API_HOST="http://vllm-nginx-proxy:8000"
VLLM_API_KEY="sk-my-secret-vllm-key"
DEEPSEEK_API_KEY="deepseekApiKeyHere"

# vector db (multi-provider)
# Default vector DB provider used when a site has no per-site config.
# qdrant|opensearch|elasticsearch|pinecone|weaviate|milvus|chroma|pgvector|redis|mongo-atlas
VECTOR_DB_PROVIDER="qdrant"
# AES-256-GCM key for encrypting vector DB credentials saved via the admin UI.
# MUST change in production. Use the SAME value for webapp and ai-service (common.env is shared).
# e.g. openssl rand -base64 48
VECTOR_DB_ENCRYPTION_KEY="changeThisVectorDBEncryptionKey"
# Set connection vars only for the provider chosen in VECTOR_DB_PROVIDER.
# qdrant uses QDRANT_CLUSTER_URL / QDRANT_API_KEY above.
# OpenSearch (TLS 는 URL 스킴 http/https 로 결정)
#OPENSEARCH_ENDPOINT="https://opensearch:9200"
#OPENSEARCH_USERNAME="admin"
#OPENSEARCH_PASSWORD="changeThisOpenSearchPassword"
# Elasticsearch
#ELASTICSEARCH_NODE="https://elasticsearch:9200"
#ELASTICSEARCH_API_KEY="changeThisElasticApiKey"
#ELASTICSEARCH_USERNAME="elastic"
#ELASTICSEARCH_PASSWORD="changeThisElasticPassword"
# Pinecone (PINECONE_HOST = 인덱스 host URL)
#PINECONE_API_KEY="changeThisPineconeApiKey"
#PINECONE_HOST="https://your-index-xxxx.svc.region.pinecone.io"
# Weaviate
#WEAVIATE_URL="http://weaviate:8080"
#WEAVIATE_API_KEY="changeThisWeaviateApiKey"
# Milvus
#MILVUS_HOST="milvus"
#MILVUS_PORT="19530"
#MILVUS_USERNAME=""
#MILVUS_PASSWORD=""
#MILVUS_DB_NAME="default"
# Chroma
#CHROMA_URL="http://chroma:8000"
#CHROMA_API_KEY=""
#CHROMA_DATABASE="default_database"
# pgvector
#PGVECTOR_URL="postgres://user:password@pgvector:5432/vectordb"
# Redis Stack (RediSearch)
#REDIS_VECTOR_URL="redis://redis-stack:6379"
#REDIS_VECTOR_PASSWORD=""
# MongoDB Atlas
#MONGO_ATLAS_VECTOR_URL="mongodb+srv://user:password@cluster.mongodb.net"
#MONGO_ATLAS_VECTOR_DB="sclab"
#MONGO_ATLAS_VECTOR_INDEX="vector_index"