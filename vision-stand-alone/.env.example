# SCLAB Vision stand-alone 배포 설정.
# install.sh가 이 형식으로 .env를 생성한다. 직접 수정한 뒤 ./up.sh를 실행하면 된다.

# Compose 제어.
# 기본값은 비어 있다. RustFS cold-tier 녹화를 활성화할 때 s3를 사용한다.
COMPOSE_PROFILES=
# 이 줄의 주석을 해제하면 GPU 모드가 활성화된다. vision-aio를 vision-aio-gpu로 교체한다.
#COMPOSE_FILE=docker-compose.yml:docker-compose.gpu.yml

# 이미지.
VISION_REGISTRY=873379329511.dkr.ecr.ap-northeast-2.amazonaws.com/sclabio
VISION_TAG=0.1.1

# 호스트 포트.
# 아래 포트는 HTTPS proxy가 사용한다.
VISION_CONSOLE_PORT=8890
VISION_CONTROL_PORT=8090
VISION_GATEWAY_PORT=8080

# TLS 인증서.
# cert.pem과 privkey.pem이 없으면 install.sh/up.sh가 ./data/vision/certs/에 자체 서명 인증서를 생성한다.

# 내부 stand-alone 데이터 서비스.
MONGO_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=changeThisMongoPassword
REDIS_PASSWORD=changeThisRedisPassword
VISION_MONGO_URL=mongodb://root:changeThisMongoPassword@mongo:27017/?authSource=admin
VISION_MONGO_DB=sclab_vision
VISION_REDIS_URL=redis://:changeThisRedisPassword@redis:6379
VISION_STUDIO_SHARED=false
VISION_QDRANT_URL=http://qdrant:6333
VISION_QDRANT_API_KEY=changeThisQdrantApiKey
VISION_QDRANT_COLLECTION=VisionAnalysisVector

# Secret. 운영 환경에서는 교체한다. install.sh는 기본적으로 랜덤 값을 생성한다.
VISION_INTERNAL_TOKEN=sv-dev-internal-token
VISION_ADMIN_JWT_SECRET=sv-dev-admin-jwt-secret
VISION_SIGNING_KEY=dev-insecure-signing-key

# HLS embed CORS. 모든 origin을 허용하려면 *를 사용한다.
VISION_HLS_CORS_ORIGINS=*

# DVR 녹화.
VISION_RECORD_DEFAULT=off
VISION_RECORD_DELETE_AFTER=86400

# S3 cold tier. COMPOSE_PROFILES에 s3가 포함될 때 사용한다.
VISION_S3_BUCKET=
VISION_S3_ENDPOINT=http://rustfs:9000
VISION_S3_REGION=us-east-1
VISION_S3_ACCESS_KEY_ID=rustfsadmin
VISION_S3_SECRET_ACCESS_KEY=rustfsadmin
VISION_S3_PREFIX=recordings
VISION_S3_API_PORT=9000
VISION_S3_CONSOLE_PORT=9001

# 로깅.
RUST_LOG=info
