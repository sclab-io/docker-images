# SCLAB Vision 배포 설정 — install.sh가 이 형식으로 .env를 생성한다.
# (직접 편집도 가능. 변경 후: ./up.sh 또는 docker compose up -d)

# ── compose 동작 제어(특수 변수) ────────────────────────────────────────────
# 실행할 프로파일: db=전용 Mongo/Redis, s3=RustFS 녹화 저장. 쉼표로 조합(예: db,s3). 공유 DB면 비움.
COMPOSE_PROFILES=db
# GPU 사용 시 아래 주석 해제(aio-gpu로 교체 + GPU 예약). 미설정=CPU.
#COMPOSE_FILE=docker-compose.yml:docker-compose.gpu.yml

# ── 이미지 ───────────────────────────────────────────────────────────────────
VISION_REGISTRY=873379329511.dkr.ecr.ap-northeast-2.amazonaws.com/sclabio
VISION_TAG=latest

# ── 외부 포트(호스트) ─────────────────────────────────────────────────────────
VISION_CONSOLE_PORT=8890    # 콘솔 웹 UI  → http://<host>:8890
VISION_CONTROL_PORT=8090    # 제어 API
VISION_GATEWAY_PORT=8080    # HLS gateway(외부 재생 표면)

# ── 상태(Mongo/Redis) ─────────────────────────────────────────────────────────
# 전용(COMPOSE_PROFILES=db) 기본값. SCLAB Studio 공유 시 studio의 mongo/redis로 바꾸고 STUDIO_SHARED=true.
VISION_MONGO_URL=mongodb://vision-mongo:27017
VISION_MONGO_DB=vision
VISION_REDIS_URL=redis://vision-redis:6379
VISION_STUDIO_SHARED=false

# ── 시크릿(운영 필수 교체 — 세 값은 aio/console이 공유) ─────────────────────────
VISION_INTERNAL_TOKEN=sv-dev-internal-token
VISION_ADMIN_JWT_SECRET=sv-dev-admin-jwt-secret
VISION_SIGNING_KEY=dev-insecure-signing-key

# ── HLS 임베드 CORS(콘솔/웹앱 오리진, * = 전체 허용) ────────────────────────────
VISION_HLS_CORS_ORIGINS=*

# ── DVR 녹화(선택) ─────────────────────────────────────────────────────────────
VISION_RECORD_DEFAULT=off        # off=녹화안함, always=활성 카메라 상시녹화
VISION_RECORD_DELETE_AFTER=86400 # hot(디스크) 보존 초. 만료분은 S3(cold)로 이관 후 삭제

# ── S3 cold tier(COMPOSE_PROFILES에 s3 포함 시) — 비우면 디스크 전용 ──────────────
VISION_S3_BUCKET=
VISION_S3_ENDPOINT=http://rustfs:9000
VISION_S3_REGION=us-east-1
VISION_S3_ACCESS_KEY_ID=rustfsadmin
VISION_S3_SECRET_ACCESS_KEY=rustfsadmin
VISION_S3_PREFIX=recordings
VISION_S3_API_PORT=9000
VISION_S3_CONSOLE_PORT=9001

# ── 로그 레벨 ─────────────────────────────────────────────────────────────────
RUST_LOG=info
