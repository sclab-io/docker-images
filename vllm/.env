# Specify the HuggingFace model ID to use. 
MODEL_ID=Qwen/Qwen2.5-1.5B-Instruct

# Set embedding model ID
EMBED_MODEL_ID=mixedbread-ai/mxbai-embed-large-v1

# For models requiring access permission, uncomment the token below and enter the issued token.
#HUGGING_FACE_HUB_TOKEN=

# Set API key to use when accessing vLLM API server
VLLM_API_KEY=sk-my-secret-vllm-key
